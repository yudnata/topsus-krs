# Frontend Vue (Vite) — salin ke frontend/.env (development lokal)
# Production: set di Vercel → Project → Settings → Environment Variables
# Variabel harus diawali VITE_ agar ter-bundle ke browser

# Development (backend lokal)
VITE_API_URL=http://localhost:8080

# Production (set di Vercel Dashboard)
# VITE_API_URL=https://krs-api-xxx.azurewebsites.net
