# HANYA untuk Docker Compose di laptop — BUKAN untuk Vercel/Azure deploy.
# Salin: cp .env.example .env  (di folder root, untuk `docker compose up`)
#
# Deploy cloud:
#   - Frontend env  → Vercel Dashboard (VITE_API_URL), lihat frontend/.env.example
#   - Backend env   → Azure App Settings, lihat backend/.env.example

# PostgreSQL (docker-compose)
POSTGRES_USER=krs
POSTGRES_PASSWORD=krs_secret
POSTGRES_DB=krs_db
POSTGRES_PORT=5434

# Redis (docker-compose)
REDIS_PORT=6379

# Connection strings untuk backend/.env
# Lokal (docker compose):
# DATABASE_URL=postgres://krs:krs_secret@localhost:5434/krs_db?sslmode=disable
# Cloud (Neon Console → Connection details → Pooled):
# DATABASE_URL=postgres://user:pass@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# REDIS_URL=redis://localhost:6379/0
